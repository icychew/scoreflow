# Application
APP_NAME=ScoreFlow
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key

# Database
DATABASE_URL=postgresql://scoreflow:scoreflow@localhost:5432/scoreflow

# Redis
REDIS_URL=redis://localhost:6379/0

# S3 / MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=scoreflow-uploads
S3_REGION=us-east-1

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# File Upload
MAX_UPLOAD_SIZE_MB=50
ALLOWED_AUDIO_EXTENSIONS=mp3,wav,flac

# JWT Auth
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Roboflow OMR Validation (optional — leave blank to disable)
# Get your API key at https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=your_api_key_here
# Format: <workspace>/<model-slug>/<version>  e.g. my-workspace/music-omr/1
ROBOFLOW_MODEL_ID=your-workspace/your-model/1
# Minimum detection confidence (0.0–1.0), default 0.4
ROBOFLOW_CONFIDENCE=0.4
